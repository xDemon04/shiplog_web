---
import { Image } from 'astro:assets';
import logoImage from '../assets/images/logo.avif';

interface Props {
  title: string;
}

const { title } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = Astro.url.pathname.replace(/\/$/, "");
const isHome = currentPath === baseUrl || currentPath === "";
const isQuotePage = currentPath.endsWith('/cotizar');

const getHomeLink = (hash: string) => isHome ? hash : `${baseUrl}/${hash}`;
const getPageLink = (path: string) => `${baseUrl}${path}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="ShipLog - Soluciones de logística y transporte de carga pesada en Sudamérica" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}/favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav class="navbar">
        <div class="container">
          <a href={getPageLink("/")} class="logo">
            <Image src={logoImage} alt="ShipLog" class="logo-image" />
          </a>
          {isQuotePage ? (
            <a href={getPageLink("/")} class="btn-back-home">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Volver al Inicio</span>
            </a>
          ) : (
            <>
              <button class="mobile-menu-btn" aria-label="Menú">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
              </button>
              <ul class="nav-links">
                <li><a href={getHomeLink("#inicio")}>Inicio</a></li>
                <li><a href={getPageLink("/nosotros")}>Nosotros</a></li>
                <li><a href={getHomeLink("#servicios")}>Servicios</a></li>
                <li><a href={getHomeLink("#rutas")}>Rutas</a></li>
                <li><a href={getPageLink("/cotizar")} class="nav-cta">Cotizar</a></li>
              </ul>
            </>
          )}
        </div>
      </nav>
    </header>
    
    <main>
      <slot />
    </main>
    
    <footer>
      <div class="container">
        <div class="footer-content">
          <div class="footer-section">
            <div class="footer-logo">
              <Image src={logoImage} alt="ShipLog" class="footer-logo-image" />
            </div>
            <p>Soluciones logísticas para carga pesada en toda Sudamérica. Conectando negocios con transporte confiable y eficiente.</p>
            <div class="social-links">
              <a href="#" aria-label="LinkedIn">in</a>
              <a href="#" aria-label="Facebook">f</a>
              <a href="#" aria-label="Twitter">𝕏</a>
              <a href="#" aria-label="Instagram">📷</a>
            </div>
          </div>
          
          <div class="footer-section">
            <h4>Servicios</h4>
            <p><a href={getHomeLink("#servicios")} style="color: inherit; text-decoration: none;">Transporte de Carga Pesada</a></p>
            <p><a href={getHomeLink("#servicios")} style="color: inherit; text-decoration: none;">Logística Internacional</a></p>
            <p><a href={getHomeLink("#servicios")} style="color: inherit; text-decoration: none;">Almacenamiento</a></p>
            <p><a href={getHomeLink("#servicios")} style="color: inherit; text-decoration: none;">Gestión Aduanera</a></p>
          </div>
          
          <div class="footer-section">
            <h4>Empresa</h4>
            <p><a href={getPageLink("/nosotros")} style="color: inherit; text-decoration: none;">Sobre Nosotros</a></p>
            <p><a href={getHomeLink("#rutas")} style="color: inherit; text-decoration: none;">Nuestras Rutas</a></p>
            <p><a href={getPageLink("/cotizar")} style="color: inherit; text-decoration: none;">Cotizar</a></p>
          </div>
          
          <div class="footer-section">
            <h4>Oficinas</h4>
            <p><strong>🇧🇷 Brasil</strong><br>São Paulo • Uruguaiana</p>
            <p><strong>🇦🇷 Argentina</strong><br>Buenos Aires</p>
            <p><strong>🇨🇱 Chile</strong><br>Los Andes</p>
          </div>
          
          <div class="footer-section">
            <h4>Contacto</h4>
            <p>📧 contacto@shiplog.com</p>
            <p>📞 +XX XXX XXX XXXX</p>
            <p>⏰ Lun - Vie: 8:00 - 18:00</p>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2026 ShipLog. Todos los derechos reservados. | Política de Privacidad | Términos y Condiciones</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --primary: #1e3a8a;
    --secondary: #1e40af;
    --dark: #0A1628;
    --light: #F8FBFF;
    --accent: #1e3a8a;
    --white: #FFFFFF;
    --gray: #64748B;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    line-height: 1.6;
    color: var(--dark);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  header {
    background: #1e3a8a;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(30, 58, 138, 0.4);
    position: sticky;
    top: 0;
    z-index: 100;
    transition: all 0.3s ease;
  }

  header.scrolled {
    background: #1e40af;
    box-shadow: 0 4px 30px rgba(30, 58, 138, 0.6);
  }

  .navbar {
    padding: 1.2rem 0;
  }

  .navbar .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo-image {
    height: 45px;
    width: auto;
    transition: transform 0.3s ease;
    filter: brightness(0) invert(1); /* Hace el logo blanco */
  }

  .logo:hover .logo-image {
    transform: scale(1.05);
  }

  .btn-back-home {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: #1e3a8a;
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(255,255,255,0.2);
  }

  .btn-back-home:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.95);
  }

  .btn-back-home svg {
    transition: transform 0.3s ease;
  }

  .btn-back-home:hover svg {
    transform: translateX(-3px);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2.5rem;
  }

  .nav-links a {
    text-decoration: none;
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 0;
    height: 2px;
    background: white;
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-cta {
    background: white !important;
    color: #1e3a8a !important;
    padding: 0.6rem 1.5rem !important;
    border-radius: 50px !important;
    transition: all 0.3s ease !important;
  }

  .nav-cta:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 10px 30px rgba(255, 255, 255, 0.3) !important;
    color: #1e3a8a !important;
  }

  .nav-cta::after {
    display: none !important;
  }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 21px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 10;
  }
  
  .mobile-menu-btn .bar {
    height: 3px;
    width: 100%;
    background-color: white;
    border-radius: 3px;
    transition: all 0.3s ease;
  }

  /* Hamburger Animation */
  .mobile-menu-btn.active .bar:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .mobile-menu-btn.active .bar:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-btn.active .bar:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  section {
    padding: 4rem 0;
  }

  h2 {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: var(--dark);
    font-weight: 800;
    text-align: center;
    letter-spacing: -1px;
  }

  h3 {
    font-size: 1.8rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  /* Animaciones de scroll */
  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .slide-in-left {
    opacity: 0;
    transform: translateX(-50px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .slide-in-left.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .slide-in-right {
    opacity: 0;
    transform: translateX(50px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .slide-in-right.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .scale-in {
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .scale-in.visible {
    opacity: 1;
    transform: scale(1);
  }

  footer {
    background: var(--dark);
    color: white;
    padding: 4rem 0 2rem;
    position: relative;
    overflow: hidden;
  }

  footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  .footer-section h3, .footer-section h4 {
    color: white;
    margin-bottom: 1.5rem;
    font-weight: 700;
  }

  .footer-section h3 {
    font-size: 1.8rem;
  }

  .footer-logo {
    margin-bottom: 1.5rem;
  }

  .footer-logo-image {
    height: 40px;
    width: auto;
    filter: brightness(0) invert(1); /* Hace el logo blanco si es oscuro */
  }

  .footer-section p {
    opacity: 0.8;
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .footer-section p strong {
    opacity: 1;
    font-weight: 700;
    display: block;
    margin-bottom: 0.25rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .social-links a {
    width: 45px;
    height: 45px;
    background: rgba(255,255,255,0.1);
    color: white;
    text-decoration: none;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    font-weight: 600;
  }

  .social-links a:hover {
    background: var(--primary);
    transform: translateY(-3px);
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .mobile-menu-btn {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--primary);
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      padding: 2rem;
      border-top: 1px solid rgba(255,255,255,0.1);
      clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
      transition: clip-path 0.4s ease-in-out;
    }

    .nav-links.active {
      clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
      box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .footer-content {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 2.2rem;
    }

    section {
      padding: 3rem 0;
    }
  }
</style>

<script>
  // Navbar scroll effect
  window.addEventListener('scroll', () => {
    const header = document.querySelector('header');
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  // Intersection Observer para animaciones
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, observerOptions);

  // Observar todos los elementos con clases de animación
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuBtn = document.querySelector('.mobile-menu-btn');
    const navLinks = document.querySelector('.nav-links');

    if (mobileMenuBtn && navLinks) {
      mobileMenuBtn.addEventListener('click', () => {
        mobileMenuBtn.classList.toggle('active');
        navLinks.classList.toggle('active');
        
        // Ensure menu has background when opened and not scrolled yet
        const header = document.querySelector('header');
        if (header && !header.classList.contains('scrolled') && mobileMenuBtn.classList.contains('active')) {
          header.style.background = '#1e3a8a';
        } else if (header && !header.classList.contains('scrolled')) {
          header.style.background = '';
        }
      });
      // Close menu on click link
      navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenuBtn.classList.remove('active');
          navLinks.classList.remove('active');
        });
      });
    }

    const animatedElements = document.querySelectorAll('.fade-in, .slide-in-left, .slide-in-right, .scale-in');
    animatedElements.forEach(el => observer.observe(el));
  });

  // Smooth scroll
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href') || '');
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
</script>
