---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Acerca de Nosotros - ShipLog">
  <!-- Hero Section -->
  <section class="about-hero">
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content fade-in">
        <span class="hero-badge">Quiénes Somos</span>
        <h1>Especialistas en Logística Internacional dentro del Mercosur</h1>
        <p>Más que transporte. Conectamos mercados.</p>
      </div>
    </div>
  </section>

  <!-- Quiénes Somos -->
  <section class="who-we-are">
    <div class="container">
      <div class="who-grid">
        <div class="who-image fade-in">
          <img src="/shiplog_web/images/hero-background.jpg" alt="Global Shipping Logistics" />
        </div>
        <div class="who-content fade-in">
          <h2>Quiénes Somos</h2>
          <p class="lead">
            En Shiplog somos especialistas en transporte terrestre internacional dentro del Mercosur, conectando de forma eficiente los principales mercados de Sudamérica.
          </p>
          <p>
            Articulamos soluciones logísticas que integran transporte terrestre, marítimo y aéreo, permitiendo gestionar operaciones internacionales de manera ágil, segura y confiable.
          </p>
          <p>
            A través de nuestra red de agentes y aliados estratégicos coordinamos operaciones de importación y exportación, optimizando cada etapa del movimiento de carga entre Sudamérica y los mercados globales.
          </p>
          <p>
            Nuestro enfoque combina experiencia operativa, coordinación logística y gestión de transporte multimodal para ofrecer soluciones eficientes adaptadas a las necesidades de cada cliente.
          </p>
          
          <div class="values-compact">
            <div class="value-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>Optimización de rutas</span>
            </div>
            <div class="value-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>Control operativo</span>
            </div>
            <div class="value-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>Seguridad en cada etapa</span>
            </div>
            <div class="value-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>Compromiso con resultados</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ¿Qué Hacemos? -->
  <section class="what-we-do">
    <div class="container">
      <div class="section-header fade-in">
        <h2>¿Qué Hacemos?</h2>
        <p>Soluciones logísticas diseñadas para empresas que necesitan resultados</p>
      </div>

      <div class="services-grid">
        <div class="service-item fade-in" style="transition-delay: 0.1s">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="1" y="3" width="15" height="13"/>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <h3>Transporte terrestre internacional</h3>
          <p>Carga exclusiva (FTL) y consolidada (LTL) con trazabilidad, eficiencia operativa y optimización de costos.</p>
        </div>

        <div class="service-item fade-in" style="transition-delay: 0.2s">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>Seguro de carga internacional</h3>
          <p>Disponibilidad de seguros de transporte para respaldar cada envío durante su operación logística multimodal</p>
        </div>

        <div class="service-item fade-in" style="transition-delay: 0.3s">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <h3>Almacenamiento y gestión de mercancías</h3>
          <p>Soluciones de resguardo, consolidación y distribución estratégica.</p>
        </div>

        <div class="service-item fade-in" style="transition-delay: 0.4s">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </div>
          <h3>Transporte marítimo y aéreo</h3>
          <p>Gestionamos transporte marítimo (FCL y LCL) y aéreo para operaciones logísticas internacionales.</p>
        </div>

        <div class="service-item fade-in" style="transition-delay: 0.5s">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
          </div>
          <h3>Asesoría en Comercio Exterior</h3>
          <p>Apoyo en la gestión de procesos de importación, exportación y logística internacional.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industrias -->
  <section class="industries">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Industrias que confían en nosotros</h2>
        <p>Operamos en sectores que exigen precisión y cumplimiento</p>
      </div>

      <div class="industries-grid">
        <div class="industry-card fade-in" style="transition-delay: 0.1s">
          <div class="industry-icon">⚗️</div>
          <h3>Industria química</h3>
        </div>
        <div class="industry-card fade-in" style="transition-delay: 0.2s">
          <div class="industry-icon">⛏️</div>
          <h3>Industria minera</h3>
        </div>
        <div class="industry-card fade-in" style="transition-delay: 0.3s">
          <div class="industry-icon">🚗</div>
          <h3>Industria automotriz</h3>
        </div>
        <div class="industry-card fade-in" style="transition-delay: 0.4s">
          <div class="industry-icon">⚡</div>
          <h3>Industria energética</h3>
        </div>
        <div class="industry-card fade-in" style="transition-delay: 0.5s">
          <div class="industry-icon">🌾</div>
          <h3>Industria agrícola</h3>
        </div>
      </div>

      <p class="industries-note fade-in">
        Adaptamos nuestras soluciones a los estándares técnicos, regulatorios y operativos de cada sector.
      </p>
    </div>
  </section>

  <!-- Tipos de Carga -->
  <section class="cargo-types">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Tipos de Carga</h2>
        <p>Movemos lo que tu negocio necesita, sin límites</p>
      </div>

      <div class="cargo-grid">
        <div class="cargo-card fade-in" style="transition-delay: 0.1s">
          <div class="cargo-image">
            <img src="/shiplog_web/images/hero-background.jpg" alt="Carga refrigerada" />
            <div class="cargo-overlay"></div>
          </div>
          <div class="cargo-content">
            <h3>Carga refrigerada</h3>
          </div>
        </div>

        <div class="cargo-card fade-in" style="transition-delay: 0.2s">
          <div class="cargo-image">
            <img src="/shiplog_web/images/hero-background.jpg" alt="Carga peligrosa" />
            <div class="cargo-overlay"></div>
          </div>
          <div class="cargo-content">
            <h3>Carga peligrosa (IMO)</h3>
          </div>
        </div>

        <div class="cargo-card fade-in" style="transition-delay: 0.3s">
          <div class="cargo-image">
            <img src="/shiplog_web/images/hero-background.jpg" alt="Carga general seca" />
            <div class="cargo-overlay"></div>
          </div>
          <div class="cargo-content">
            <h3>Carga general seca</h3>
          </div>
        </div>

        <div class="cargo-card fade-in" style="transition-delay: 0.4s">
          <div class="cargo-image">
            <img src="/shiplog_web/images/hero-background.jpg" alt="Contenedores" />
            <div class="cargo-overlay"></div>
          </div>
          <div class="cargo-content">
            <h3>Traslado internacional de contenedores</h3>
          </div>
        </div>
      </div>

      <p class="cargo-note fade-in">
        Gestionamos cada tipo de mercancía bajo protocolos específicos de seguridad y control.
      </p>
    </div>
  </section>

  <!-- Flota y Capacidad -->
  <section class="fleet">
    <div class="container">
      <div class="section-header fade-in">
        <h2>Flota y Capacidad</h2>
        <p>Infraestructura preparada para cada desafío logístico</p>
      </div>

      <div class="fleet-grid">
        <div class="fleet-card fade-in" style="transition-delay: 0.1s">
          <div class="fleet-image">
            <img src="/shiplog_web/images/hero-background.jpg" alt="Semirremolque abierto" />
          </div>
          <div class="fleet-info">
            <h3>Semirremolque abierto</h3>
            <p class="fleet-desc">Versatilidad y eficiencia operativa</p>
            <div class="fleet-specs">
              <span>Capacidad hasta 28 tn</span>
              <span>13,5 – 14,5 m</span>
            </div>
          </div>
        </div>

        <div class="fleet-card fade-in" style="transition-delay: 0.2s">
          <div class="fleet-image">
            <img src="/shiplog_web/images/hero-background.jpg" alt="Sider" />
          </div>
          <div class="fleet-info">
            <h3>Sider</h3>
            <p class="fleet-desc">Mayor protección estructural</p>
            <div class="fleet-specs">
              <span>26–27 tn</span>
              <span>90 m³</span>
            </div>
          </div>
        </div>

        <div class="fleet-card fade-in" style="transition-delay: 0.3s">
          <div class="fleet-image">
            <img src="/shiplog_web/images/hero-background.jpg" alt="Furgón seco" />
          </div>
          <div class="fleet-info">
            <h3>Furgón seco</h3>
            <p class="fleet-desc">Seguridad para carga valiosa</p>
            <div class="fleet-specs">
              <span>Hasta 25 tn</span>
              <span>60–95 m³</span>
            </div>
          </div>
        </div>

        <div class="fleet-card fade-in" style="transition-delay: 0.4s">
          <div class="fleet-image">
            <img src="/shiplog_web/images/hero-background.jpg" alt="Furgón refrigerado" />
          </div>
          <div class="fleet-info">
            <h3>Furgón refrigerado</h3>
            <p class="fleet-desc">Control térmico especializado</p>
            <div class="fleet-specs">
              <span>Hasta 25 tn</span>
              <span>Refrigerado / Congelado</span>
            </div>
          </div>
        </div>

        <div class="fleet-card fade-in" style="transition-delay: 0.5s">
          <div class="fleet-image">
            <img src="/shiplog_web/images/hero-background.jpg" alt="Cama baja" />
          </div>
          <div class="fleet-info">
            <h3>Cama baja</h3>
            <p class="fleet-desc">Transporte de maquinaria y cargas sobredimensionadas</p>
          </div>
        </div>
      </div>

      <p class="fleet-note fade-in">
        Flota moderna, mantenimiento riguroso y disponibilidad operativa permanente.
      </p>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box fade-in">
        <h2>¿Listo para optimizar tu logística?</h2>
        <p>Conectamos tu negocio con soluciones de transporte internacional confiables y eficientes</p>
        <a href="/shiplog_web/cotizar" class="btn-cta">
          <span>Solicitar Cotización</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>


<style>
  /* Hero Section */
  .about-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: url('/images/hero-background.jpg') center/cover;
    opacity: 0.15;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: white;
    padding: 2rem;
    max-width: 900px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(10px);
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255,255,255,0.3);
  }

  .hero-content h1 {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .hero-content p {
    font-size: 1.4rem;
    opacity: 0.95;
  }

  /* Quiénes Somos */
  .who-we-are {
    padding: 6rem 0;
    background: white;
  }

  .who-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .who-image {
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(30,58,138,0.2);
  }

  .who-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .who-content h2 {
    font-size: 2.8rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1.5rem;
  }

  .who-content .lead {
    font-size: 1.3rem;
    font-weight: 500;
    color: #1e3a8a;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .who-content p {
    font-size: 1.1rem;
    color: #64748b;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .values-compact {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }

  .value-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    color: #0f172a;
    font-weight: 600;
  }

  .value-item svg {
    color: #2563eb;
    flex-shrink: 0;
  }

  /* Section Header */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-header h2 {
    font-size: 3rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .section-header p {
    font-size: 1.2rem;
    color: #64748b;
  }

  /* ¿Qué Hacemos? */
  .what-we-do {
    padding: 6rem 0;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .service-item {
    background: white;
    padding: 2.5rem;
    border-radius: 20px;
    border: 1px solid rgba(30,58,138,0.08);
    transition: all 0.3s ease;
  }

  .service-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(30,58,138,0.15);
    border-color: rgba(37,99,235,0.2);
  }

  .service-icon {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #2563eb;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
  }

  .service-item:hover .service-icon {
    background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    color: white;
    transform: scale(1.1) rotate(5deg);
  }

  .service-item h3 {
    font-size: 1.4rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
  }

  .service-item p {
    font-size: 1.05rem;
    color: #64748b;
    line-height: 1.7;
  }

  /* Industrias */
  .industries {
    padding: 6rem 0;
    background: white;
  }

  .industries-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .industry-card {
    background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
    padding: 2rem;
    border-radius: 20px;
    border: 1px solid rgba(30,58,138,0.08);
    text-align: center;
    transition: all 0.3s ease;
  }

  .industry-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(30,58,138,0.12);
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
  }

  .industry-card:hover h3 {
    color: white;
  }

  .industry-card:hover .industry-icon {
    transform: scale(1.2);
  }

  .industry-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    transition: transform 0.3s ease;
  }

  .industry-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    transition: color 0.3s ease;
  }

  .industries-note {
    text-align: center;
    font-size: 1.1rem;
    color: #64748b;
    font-style: italic;
  }

  /* Tipos de Carga */
  .cargo-types {
    padding: 6rem 0;
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  }

  .cargo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .cargo-card {
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(30,58,138,0.1);
  }

  .cargo-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(30,58,138,0.2);
  }

  .cargo-image {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .cargo-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .cargo-card:hover .cargo-image img {
    transform: scale(1.1);
  }

  .cargo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(30,58,138,0.8) 100%);
  }

  .cargo-content {
    background: white;
    padding: 1.5rem;
  }

  .cargo-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    text-align: center;
  }

  .cargo-note {
    text-align: center;
    font-size: 1rem;
    color: #64748b;
    font-style: italic;
  }

  /* Flota */
  .fleet {
    padding: 6rem 0;
    background: white;
  }

  .fleet-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .fleet-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(30,58,138,0.08);
    transition: all 0.3s ease;
  }

  .fleet-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(30,58,138,0.15);
  }

  .fleet-image {
    height: 200px;
    overflow: hidden;
  }

  .fleet-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .fleet-card:hover .fleet-image img {
    transform: scale(1.05);
  }

  .fleet-info {
    padding: 2rem;
  }

  .fleet-info h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  .fleet-desc {
    font-size: 1rem;
    color: #64748b;
    margin-bottom: 1rem;
  }

  .fleet-specs {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .fleet-specs span {
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    color: #1e40af;
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .fleet-note {
    text-align: center;
    font-size: 1.1rem;
    color: #64748b;
    font-weight: 600;
  }

  /* CTA Section */
  .cta-section {
    padding: 6rem 0;
    background: white;
  }

  .cta-box {
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
    border-radius: 24px;
    padding: 4rem 3rem;
    text-align: center;
    color: white;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(30,58,138,0.25);
  }

  .cta-box::before {
    content: '';
    position: absolute;
    top: -150px;
    right: -150px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
