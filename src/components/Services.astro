      <div class="service-card-large fade-in" style="transition-delay: 0.2s">
        <div class="service-card-image">
          <img src="/shiplog_web/images/ltl.jpeg" alt="LTL Less Than Truckload" />
          <div class="service-card-overlay"></div>
        </div>
        <div class="service-card-content">
          <h3>LTL (Less Than Truckload)</h3>
          <p>Transporte de carga consolidada para envíos compartidos, optimizando costos y tiempos de tránsito.</p>
        </div>
      </div>

      <div class="service-card-large fade-in" style="transition-delay: 0.3s">
        <div class="service-card-image">
          <img src="/shiplog_web/images/insurance.jpeg" alt="Seguro de carga" />
          <div class="service-card-overlay"></div>
        </div>
        <div class="service-card-content">
          <h3>Seguro de carga internacional</h3>
          <p>Protección integral para mercancías en cualquier modalidad de transporte.</p>
        </div>
      </div>

      <div class="service-card-large fade-in" style="transition-delay: 0.4s">
        <div class="service-card-image">
          <img src="shiplog_web/images/almc.jpeg" alt="Almacenamiento" />
          <div class="service-card-overlay"></div>
        </div>
        <div class="service-card-content">
          <h3>Almacenamiento y gestión</h3>
          <p>Soluciones de resguardo, consolidación y distribución estratégica.</p>
        </div>
      </div>

      <div class="service-card-large fade-in" style="transition-delay: 0.5s">
        <div class="service-card-image">
          <img src="/shiplog_web/images/logistica.jpeg" alt="Conectividad global" />
          <div class="service-card-overlay"></div>
        </div>
        <div class="service-card-content">
          <h3>Conectividad marítima y aérea</h3>
          <p>Articulamos tu operación con navieras, aerolíneas y agentes internacionales.</p>
        </div>
      </div>
    </div>

    <button class="carousel-btn carousel-btn-next" aria-label="Siguiente">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.querySelector('.carousel-track') as HTMLElement;
    const prevBtn = document.querySelector('.carousel-btn-prev') as HTMLButtonElement;
    const nextBtn = document.querySelector('.carousel-btn-next') as HTMLButtonElement;
    
    if (!carousel || !prevBtn || !nextBtn) return;

    let isDown = false;
    let startX: number;
    let scrollLeft: number;
    let isDragging = false;

    // Mouse drag functionality
    carousel.addEventListener('mousedown', (e: MouseEvent) => {
      isDown = true;
      isDragging = false;
      carousel.style.cursor = 'grabbing';
      carousel.style.userSelect = 'none';
      startX = e.pageX - carousel.offsetLeft;
      scrollLeft = carousel.scrollLeft;
    });

    carousel.addEventListener('mouseleave', () => {
      isDown = false;
      carousel.style.cursor = 'grab';
    });

    carousel.addEventListener('mouseup', () => {
      isDown = false;
      carousel.style.cursor = 'grab';
    });

    carousel.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isDown) return;
      e.preventDefault();
      isDragging = true;
      const x = e.pageX - carousel.offsetLeft;
      const walk = (x - startX);
      carousel.scrollLeft = scrollLeft - walk;
    });

    // Prevent click events when dragging
    carousel.addEventListener('click', (e: MouseEvent) => {
      if (isDragging) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);

    // Button navigation
    const cardWidth = 380 + 24; // card width + gap

    prevBtn.addEventListener('click', () => {
      carousel.scrollBy({
        left: -cardWidth,
        behavior: 'smooth'
      });
    });

    nextBtn.addEventListener('click', () => {
      carousel.scrollBy({
        left: cardWidth,
        behavior: 'smooth'
      });
    });

    // Update button states
    const updateButtons = () => {
      const maxScroll = carousel.scrollWidth - carousel.clientWidth;
      
      if (carousel.scrollLeft <= 5) {
        prevBtn.disabled = true;
      } else {
        prevBtn.disabled = false;
      }
      
      if (carousel.scrollLeft >= maxScroll - 5) {
        nextBtn.disabled = true;
      } else {
        nextBtn.disabled = false;
      }
    };

    carousel.addEventListener('scroll', updateButtons);
    window.addEventListener('resize', updateButtons);
    
    // Initial update
    setTimeout(updateButtons, 100);
  });
</script>

<style>
