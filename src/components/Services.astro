---
---

<section id="servicios" class="services">
  <div class="services-wrapper">
    <div class="services-header fade-in">
      <span class="header-badge">Nuestros Servicios</span>
      <h2>Soluciones Logísticas Integrales</h2>
      <p class="header-subtitle">Servicios especializados diseñados para optimizar cada etapa de su cadena de suministro</p>
    </div>

    <div class="services-grid">
      <!-- Servicio 1 - Featured -->
      <div class="service-card featured fade-in" style="transition-delay: 0.1s">
        <div class="service-background">
          <img src="/images/hero-background.jpg" alt="Transporte de Carga Pesada" />
          <div class="service-gradient"></div>
        </div>
        <div class="service-content">
          <div class="service-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="1" y="3" width="15" height="13"/>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <h3>Transporte de Carga Pesada</h3>
          <p>Movemos maquinaria industrial, equipos de gran tonelaje y mercancías especiales con la máxima seguridad y eficiencia.</p>
          <ul class="service-features">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Hasta 50 toneladas
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Flota moderna
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              Seguros integrales
            </li>
          </ul>
          <a href="/shiplog_web/cotizar" class="service-btn">
            <span>Cotizar Ahora</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Servicio 2 -->
      <div class="service-card fade-in" style="transition-delay: 0.2s">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <h3>Logística Internacional</h3>
        <p>Conectamos 8 países de Sudamérica con rutas optimizadas y gestión aduanera completa.</p>
        <div class="service-stat">
          <span class="stat-number">8</span>
          <span class="stat-label">Países conectados</span>
        </div>
      </div>

      <!-- Servicio 3 -->
      <div class="service-card fade-in" style="transition-delay: 0.3s">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <h3>Rastreo GPS 24/7</h3>
        <p>Monitoreo en tiempo real de su carga con tecnología GPS de última generación.</p>
        <div class="service-stat">
          <span class="stat-number">24/7</span>
          <span class="stat-label">Monitoreo activo</span>
        </div>
      </div>

      <!-- Servicio 4 -->
      <div class="service-card fade-in" style="transition-delay: 0.4s">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <h3>Almacenamiento Seguro</h3>
        <p>Bodegas estratégicamente ubicadas con sistemas de seguridad avanzados.</p>
        <div class="service-stat">
          <span class="stat-number">5000m²</span>
          <span class="stat-label">Capacidad total</span>
        </div>
      </div>

      <!-- Servicio 5 -->
      <div class="service-card fade-in" style="transition-delay: 0.5s">
        <div class="service-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h3>Gestión Aduanera</h3>
        <p>Tramitación completa de documentos y asesoría especializada en comercio exterior.</p>
        <div class="service-stat">
          <span class="stat-number">100%</span>
          <span class="stat-label">Éxito en trámites</span>
        </div>
      </div>
    </div>

    <!-- CTA adicional -->
    <div class="services-cta fade-in">
      <div class="cta-content">
        <h3>¿Necesita un servicio personalizado?</h3>
        <p>Diseñamos soluciones logísticas a medida para su negocio</p>
      </div>
      <a href="/shiplog_web/cotizar" class="cta-btn">
        <span>Contactar Ahora</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>


<style>
  .services {
    background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 50%, #eff6ff 100%);
    position: relative;
    overflow: hidden;
    padding: 6rem 0;
  }

  .services::before {
    content: '';
    position: absolute;
    top: -300px;
    left: -300px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(37,99,235,0.08) 0%, transparent 70%);
    border-radius: 50%;
  }

  .services::after {
    content: '';
    position: absolute;
    bottom: -200px;
    right: -200px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(30,58,138,0.06) 0%, transparent 70%);
    border-radius: 50%;
  }

  .services-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 3rem;
    position: relative;
    z-index: 1;
  }

  .services-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .header-badge {
    display: inline-block;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    color: #1e40af;
    padding: 0.5rem 1.25rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .services-header h2 {
    font-size: 3rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .header-subtitle {
    font-size: 1.2rem;
    color: #64748b;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .service-card {
    background: white;
    padding: 2.5rem;
    border-radius: 20px;
    border: 1px solid rgba(30,58,138,0.08);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #2563eb, #3b82f6);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 60px rgba(30,58,138,0.15);
    border-color: rgba(37,99,235,0.2);
  }

  .service-card:hover::before {
    transform: scaleX(1);
  }

  /* Featured Card */
  .service-card.featured {
    grid-column: span 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    padding: 0;
    overflow: hidden;
    min-height: 400px;
  }

  .service-background {
    position: relative;
    overflow: hidden;
  }

  .service-background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .service-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(30,58,138,0.8) 0%, rgba(37,99,235,0.6) 100%);
  }

  .service-card.featured .service-content {
    padding: 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .service-icon {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #2563eb;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
  }

  .service-card:hover .service-icon {
    background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    color: white;
    transform: scale(1.1) rotate(5deg);
  }

  .service-card h3 {
    font-size: 1.6rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .service-card p {
    font-size: 1.05rem;
    color: #64748b;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .service-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    color: #64748b;
    font-weight: 500;
  }

  .service-features svg {
    color: #2563eb;
    flex-shrink: 0;
  }

  .service-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
    color: white;
    padding: 1rem 2rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(30,58,138,0.3);
    align-self: flex-start;
  }

  .service-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 40px rgba(30,58,138,0.4);
  }

  .service-btn svg {
    transition: transform 0.3s ease;
  }

  .service-btn:hover svg {
    transform: translateX(4px);
  }

  .service-stat {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(30,58,138,0.08);
    margin-top: auto;
  }

  .stat-number {
    font-size: 2.2rem;
    font-weight: 900;
    color: #2563eb;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.9rem;
    color: #64748b;
    font-weight: 600;
  }

  /* Services CTA */
  .services-cta {
    background: linear-gradient(135deg, #f8fafc 0%, #e0f2fe 100%);
    border-radius: 20px;
    padding: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    border: 1px solid rgba(30,58,138,0.1);
  }

  .cta-content h3 {
    font-size: 1.8rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  .cta-content p {
    font-size: 1.1rem;
    color: #64748b;
    margin: 0;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
    color: white;
    padding: 1.1rem 2.5rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 30px rgba(30,58,138,0.3);
    white-space: nowrap;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 40px rgba(30,58,138,0.4);
  }

  .cta-btn svg {
    transition: transform 0.3s ease;
  }

  .cta-btn:hover svg {
    transform: translateX(4px);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .services-wrapper {
      padding: 0 2rem;
    }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .service-card.featured {
      grid-column: span 2;
      grid-template-columns: 1fr;
    }

    .service-background {
      min-height: 300px;
    }
  }

  @media (max-width: 768px) {
    .services {
      padding: 4rem 0;
    }

    .services-wrapper {
      padding: 0 1.5rem;
    }

    .services-header h2 {
      font-size: 2.2rem;
    }

    .header-subtitle {
      font-size: 1.05rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card.featured {
      grid-column: span 1;
    }

    .service-card {
      padding: 2rem;
    }

    .service-card.featured .service-content {
      padding: 2rem;
    }

    .services-cta {
      flex-direction: column;
      text-align: center;
      padding: 2rem;
    }

    .cta-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
