---
---

<section id="nosotros" class="about">
  <div class="container">
    <div class="about-header fade-in">
      <span class="header-badge">Por qué elegirnos</span>
      <h2>Líderes en Logística Internacional</h2>
      <p class="header-subtitle">Conectamos Sudamérica con soluciones de transporte confiables, seguras y eficientes</p>
    </div>

    <div class="about-content">
      <!-- Grid de características principales -->
      <div class="features-grid">
        <div class="feature-card fade-in" style="transition-delay: 0.1s">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
          </div>
          <h3>Seguridad Garantizada</h3>
          <p>Protocolos certificados internacionales, seguros integrales y monitoreo 24/7 para proteger su carga en todo momento.</p>
          <div class="feature-stat">
            <span class="stat-value">98%</span>
            <span class="stat-label">Entregas sin incidentes</span>
          </div>
        </div>

        <div class="feature-card fade-in" style="transition-delay: 0.2s">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
          </div>
          <h3>Puntualidad Comprobada</h3>
          <p>Rutas optimizadas y planificación estratégica que garantizan entregas a tiempo, cada vez.</p>
          <div class="feature-stat">
            <span class="stat-value">95%</span>
            <span class="stat-label">Entregas puntuales</span>
          </div>
        </div>

        <div class="feature-card fade-in" style="transition-delay: 0.3s">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
          </div>
          <h3>Rastreo en Tiempo Real</h3>
          <p>Tecnología GPS avanzada que le permite monitorear su carga en cada kilómetro del trayecto.</p>
          <div class="feature-stat">
            <span class="stat-value">24/7</span>
            <span class="stat-label">Monitoreo activo</span>
          </div>
        </div>

        <div class="feature-card fade-in" style="transition-delay: 0.4s">
          <div class="feature-icon-wrapper">
            <div class="feature-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
          </div>
          <h3>Equipo Profesional</h3>
          <p>Conductores certificados y personal especializado con años de experiencia en logística internacional.</p>
          <div class="feature-stat">
            <span class="stat-value">5+</span>
            <span class="stat-label">Años de experiencia</span>
          </div>
        </div>
      </div>

      <!-- Sección de cobertura -->
      <div class="coverage-section fade-in">
        <div class="coverage-content">
          <div class="coverage-badge">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
            <span>Cobertura Regional</span>
          </div>
          <h3>Conectamos 8 Países de Sudamérica</h3>
          <p>Operamos en las principales rutas comerciales del Mercosur, conectando Brasil, Argentina, Chile, Perú, Paraguay, Uruguay, Bolivia y Colombia.</p>
          <div class="countries-list">
            <span class="country-tag">🇧🇷 Brasil</span>
            <span class="country-tag">🇦🇷 Argentina</span>
            <span class="country-tag">🇨🇱 Chile</span>
            <span class="country-tag">🇵🇪 Perú</span>
            <span class="country-tag">🇵🇾 Paraguay</span>
            <span class="country-tag">🇺🇾 Uruguay</span>
            <span class="country-tag">🇧🇴 Bolivia</span>
            <span class="country-tag">🇨🇴 Colombia</span>
          </div>
        </div>
        <div class="coverage-stats">
          <div class="mini-stat">
            <div class="mini-stat-number">10,000+</div>
            <div class="mini-stat-label">Toneladas Transportadas</div>
          </div>
          <div class="mini-stat">
            <div class="mini-stat-number">500+</div>
            <div class="mini-stat-label">Clientes Satisfechos</div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="about-cta fade-in">
        <a href="/shiplog_web/cotizar" class="btn-primary-cta">
          <span>Solicitar Cotización Gratuita</span>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 50%, #ffffff 100%);
    position: relative;
    overflow: hidden;
  }

  .about::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(37,99,235,0.08) 0%, transparent 70%);
    border-radius: 50%;
  }

  .about::after {
    content: '';
    position: absolute;
    bottom: -200px;
    left: -200px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(30,58,138,0.06) 0%, transparent 70%);
    border-radius: 50%;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  .about-header {
    text-align: center;
    margin-bottom: 4rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .header-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    color: #1e40af;
    padding: 0.5rem 1.25rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .about-header h2 {
    font-size: 3rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .header-subtitle {
    font-size: 1.2rem;
    color: #64748b;
    line-height: 1.7;
    font-weight: 400;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  /* Features Grid */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background: white;
    padding: 2.5rem;
    border-radius: 20px;
    border: 1px solid rgba(30,58,138,0.08);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #2563eb, #3b82f6);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 60px rgba(30,58,138,0.15);
    border-color: rgba(37,99,235,0.2);
  }

  .feature-card:hover::before {
    transform: scaleX(1);
  }

  .feature-icon-wrapper {
    margin-bottom: 1.5rem;
  }

  .feature-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #2563eb;
    transition: all 0.3s ease;
  }

  .feature-card:hover .feature-icon {
    background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
    color: white;
    transform: scale(1.1) rotate(5deg);
  }

  .feature-card h3 {
    font-size: 1.4rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .feature-card p {
    font-size: 1rem;
    color: #64748b;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .feature-stat {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(30,58,138,0.08);
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 900;
    color: #2563eb;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    color: #64748b;
    font-weight: 600;
  }

  /* Coverage Section */
  .coverage-section {
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
    border-radius: 24px;
    padding: 3rem;
    color: white;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .coverage-section::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
    border-radius: 50%;
  }

  .coverage-content {
    position: relative;
    z-index: 1;
  }

  .coverage-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(10px);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255,255,255,0.2);
  }

  .coverage-content h3 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .coverage-content p {
    font-size: 1.05rem;
    line-height: 1.7;
    opacity: 0.95;
    margin-bottom: 2rem;
  }

  .countries-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .country-tag {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(10px);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    border: 1px solid rgba(255,255,255,0.2);
    transition: all 0.3s ease;
  }

  .country-tag:hover {
    background: rgba(255,255,255,0.25);
    transform: translateY(-2px);
  }

  .coverage-stats {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  .mini-stat {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.2);
    text-align: center;
  }

  .mini-stat-number {
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .mini-stat-label {
    font-size: 0.95rem;
    opacity: 0.9;
    font-weight: 500;
  }

  /* CTA */
  .about-cta {
    text-align: center;
  }

  .btn-primary-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
    color: white;
    padding: 1.25rem 3rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    box-shadow: 0 10px 40px rgba(30,58,138,0.3);
  }

  .btn-primary-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 50px rgba(30,58,138,0.4);
  }

  .btn-primary-cta svg {
    transition: transform 0.3s ease;
  }

  .btn-primary-cta:hover svg {
    transform: translateX(4px);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .coverage-section {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .about-header h2 {
      font-size: 2.2rem;
    }

    .header-subtitle {
      font-size: 1.05rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .feature-card {
      padding: 2rem;
    }

    .coverage-section {
      padding: 2rem;
    }

    .coverage-content h3 {
      font-size: 1.6rem;
    }

    .btn-primary-cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>
