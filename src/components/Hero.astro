---
import { getImage } from "astro:assets";
import heroBg from "../assets/images/hero-background.png";

const { src: optimizedBackgroundSrc } = await getImage({ src: heroBg, format: 'avif' });
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<section id="inicio" class="hero">
  <div class="hero-background">
    <div class="hero-image" style={`background-image: url(${optimizedBackgroundSrc});`}></div>
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-container">
    <div class="hero-content fade-in">
      <div class="hero-badge">LOGÍSTICA INTERNACIONAL ESPECIALIZADA</div>
      <h1>Transporte de Carga<br>Terrestre Internacional</h1>
      <p class="hero-subtitle">Conectamos estratégicamente Brasil, Argentina, Chile, Perú, Paraguay y Uruguay.</p>
      <p class="hero-description">Optimización de rutas, trazabilidad y gestión integral para empresas que requieren precisión logística en el Mercosur.</p>
      <div class="hero-buttons">
        <a href={`${baseUrl}/cotizar`} class="btn btn-primary">Solicitar Cotización</a>
        <a href="#servicios" class="btn btn-secondary">Conocer Nuestra Flota</a>
      </div>
      <div class="hero-stats">
        <div class="stat-item scale-in">
          <div class="stat-number counter" data-target="5" data-suffix="+">0</div>
          <div class="stat-label">Años de Experiencia</div>
        </div>
        <div class="stat-item scale-in" style="transition-delay: 0.1s">
          <div class="stat-number counter" data-target="10000" data-suffix="+">0</div>
          <div class="stat-label">Toneladas Transportadas</div>
        </div>
        <div class="stat-item scale-in" style="transition-delay: 0.2s">
          <div class="stat-number counter" data-target="7">0</div>
          <div class="stat-label">Países Conectados</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    color: white;
    padding: 10rem 0 8rem;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-container {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-left: 80px;
    padding-right: 20px;
  }

  /* AQUÍ COLOCAS TU IMAGEN DE FONDO */
  .hero-image {
    position: absolute;
    inset: 0;
    /* Opción 1: Usando background-image (recomendado) */
    background-image: url('/shiplog_web/images/hero-background.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    
    /* Filtros para bajar el contraste y suavizar la imagen */
    filter: contrast(0.8) brightness(0.9);
    
    /* Opción 2: Si prefieres usar una etiqueta <img>, comenta lo de arriba y usa esto:
    <img src="/images/hero-background.jpg" alt="Background" style="width: 100%; height: 100%; object-fit: cover;" />
    */
  }

  /* Overlay con gradiente para oscurecer la imagen y hacer el texto legible */
  .hero-overlay {
    position: absolute;
    inset: 0;
    /* Gradiente oscuro de izquierda a derecha para que el texto sea legible */
    background: linear-gradient(
      to right, 
      rgba(0, 0, 0, 0.85) 0%, 
      rgba(0, 0, 0, 0.6) 50%,
      rgba(0, 0, 0, 0.3) 100%
    );
  }

  @keyframes float {
    0%, 100% { 
      transform: translateY(0px); 
    }
    50% { 
      transform: translateY(-20px); 
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 650px;
    text-align: left;
    margin: 0;
  }

  .hero-badge {
    display: inline-block;
    background: transparent;
    padding: 0;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
  }

  .hero-content h1 {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
    color: white;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1px;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: white;
    line-height: 1.6;
    font-weight: 400;
  }

  .hero-description {
    font-size: 1rem;
    margin-bottom: 2.5rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.7;
    font-weight: 300;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .hero-stats {
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .stat-item {
    text-align: left;
  }

  .stat-number {
    font-size: 2.4rem;
    font-weight: 900;
    color: white;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
  }

  .btn {
    padding: 0.9rem 2rem;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  }

  .btn-primary {
    background: #2563eb;
    color: white;
  }

  .btn-primary:hover {
    background: #1d4ed8;
  }

  .btn-secondary {
    background: transparent;
    color: white;
    border: 2px solid rgba(255,255,255,0.5);
  }

  .btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.8);
  }

  @media (max-width: 768px) {
    .hero {
      padding: 7rem 0 4rem;
      min-height: auto;
    }

    .hero-container {
      padding-left: 20px;
      padding-right: 20px;
    }

    .hero-content {
      max-width: 100%;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero-badge {
      font-size: 0.7rem;
      margin-bottom: 1.2rem;
      text-align: center;
    }

    .hero-content h1 {
      font-size: 2.3rem;
      letter-spacing: -0.5px;
      line-height: 1.2;
    }
    
    .hero-subtitle {
      font-size: 1.05rem;
      text-align: center;
    }

    .hero-description {
      font-size: 0.95rem;
      text-align: center;
      margin-bottom: 2rem;
    }

    .hero-buttons {
      width: 100%;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 2.5rem;
    }

    .btn {
      width: 100%;
      justify-content: center;
      padding: 1rem 1.5rem;
      font-size: 1rem;
    }

    .hero-stats {
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      width: 100%;
      background: rgba(255,255,255,0.08);
      padding: 2rem 1.5rem;
      border-radius: 16px;
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.1);
    }

    .stat-item {
      text-align: center;
      width: 100%;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.15);
    }
    
    .stat-item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .stat-number {
      font-size: 2.2rem;
      margin-bottom: 0.25rem;
    }

    .stat-label {
      font-size: 0.85rem;
    }
  }
</style>




<script>
  // Animación de contador tipo ruleta
  function animateCounter(element: HTMLElement) {
    const target = parseInt(element.getAttribute('data-target') || '0');
    const suffix = element.getAttribute('data-suffix') || '';
    const duration = 2000;
    const increment = target / (duration / 16);
    let current = 0;
    
    const updateCounter = () => {
      current += increment;
      
      if (current < target) {
        const displayValue = Math.floor(current).toLocaleString('es-ES');
        element.textContent = displayValue + suffix;
        requestAnimationFrame(updateCounter);
      } else {
        const displayValue = target.toLocaleString('es-ES');
        element.textContent = displayValue + suffix;
      }
    };
    
    updateCounter();
  }

  document.addEventListener('DOMContentLoaded', () => {
    const counters = document.querySelectorAll('.counter');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const counter = entry.target as HTMLElement;
          setTimeout(() => {
            animateCounter(counter);
          }, 500);
          observer.unobserve(counter);
        }
      });
    }, { threshold: 0.5 });

    counters.forEach(counter => observer.observe(counter));
  });
</script>
